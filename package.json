{
  "name": "focus-jiejie",
  "version": "0.1.3",
  "description": "专注结界：一键封锁诱惑网站的中文 Windows 专注桌面应用 MVP",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:admin": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-admin.ps1",
    "icons": "node scripts/generate-icons.js",
    "check": "node --check src/main.js && node --check src/hostsManager.js && node --check src/preload.js && node --check src/renderer/renderer.js && node --check scripts/electron-ui-smoke-test.js && node --check scripts/preload-ui-smoke.js && node --check scripts/generate-icons.js && node --check scripts/icon-resource.js && node --check scripts/after-pack.js",
    "test:ui": "electron scripts/electron-ui-smoke-test.js",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "keywords": [
    "focus",
    "website-blocker",
    "windows",
    "electron",
    "hosts"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.focusjiejie.app",
    "productName": "专注结界",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "scripts/apply-hosts.ps1",
      "scripts/run-admin.ps1",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "assets/icon.png"
      },
      {
        "from": "assets/icon.ico",
        "to": "assets/icon.ico"
      }
    ],
    "asarUnpack": [
      "scripts/*.ps1"
    ],
    "afterPack": "scripts/after-pack.js",
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "FocusJiejie-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  }
}
